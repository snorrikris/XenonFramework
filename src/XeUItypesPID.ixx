		PID::CWF_BTN_MIN_HOT,
		PID::CWF_BTN_MIN_UP,
		PID::CWF_BTN_MAX_DN,
		PID::CWF_BTN_MAX_HOT,
		PID::CWF_BTN_MAX_UP,
		PID::CWF_BTN_RST_DN,
		PID::CWF_BTN_RST_HOT,
		PID::CWF_BTN_RST_UP,
