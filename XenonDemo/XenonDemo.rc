        MENUITEM SEPARATOR
        MENUITEM "Move to first tab",           ID__MOVETOFIRSTTAB
        MENUITEM "Move to last tab",            ID__MOVETOLASTTAB
        MENUITEM "Move left",                   ID__MOVELEFT
        MENUITEM "Move right",                  ID__MOVERIGHT
        MENUITEM SEPARATOR
        MENUITEM "Close this tab",              ID__CLOSETHISTAB
        MENUITEM "Close other tabs",            ID__CLOSEOTHERTABS
        MENUITEM "Close All to the Left",       ID__CLOSEALLTOTHELEFT
        MENUITEM "Close All to the Right",      ID__CLOSEALLTOTHERIGHT
        MENUITEM "Close all but pinned tabs",   ID__CLOSEALLBUTPINNED
        MENUITEM SEPARATOR
        MENUITEM "Pin tab",                     ID__PINTAB
    END
END

