	CWF_BTN_MIN_HOT = 82,
	CWF_BTN_MIN_UP = 83,
	CWF_BTN_MAX_DN = 84,
	CWF_BTN_MAX_HOT = 85,
	CWF_BTN_MAX_UP = 86,
	CWF_BTN_RST_DN = 87,
	CWF_BTN_RST_HOT = 88,
	CWF_BTN_RST_UP = 89,
	CWF_BTN_CLS_DN = 90,
	CWF_BTN_CLS_HOT = 91,
	CWF_BTN_CLS_UP = 92,
	EL_Operational = 93,
	EL_Admin = 94,
	EL_Analytic = 95,
	EL_Debug = 96,
	FileIconDevice = 97,
	FilterRecall = 98,
	PID_MAX = 100	// Array size
};

// Note - these are all going to have a PNG graphic image in XeUIcolors.
export std::vector<PID> GetAllPIDs()
{
	return {
		PID::LogFilterPng,
		PID::TimelineCenter,
		PID::TimelineZoomIn,
		PID::TimelineZoomOut,
		PID::unused5,
		PID::eRequested,
		PID::eQueued,
		PID::eOpening,
		PID::eUnzipping,
		PID::eParsing,
		PID::eMerging,
		PID::eIndexing,
		PID::eDone,
		PID::eDoneAlreadyOpen,
		PID::eErrorFileNotFound,
		PID::eErrorNetworkPathInvalid,
		PID::eErrorAccessDenied,
		PID::eErrorOther,
		PID::eErrorUnsupportedFile,
		PID::Cancelled,
		PID::eErrorOutOfMemory,
		PID::BookmarkTogglePng,
		PID::BookmarkPrevPng,
		PID::BookmarkNextPng,
		PID::BookmarksClearPng,
		PID::BookmarkToggleWithCommentPng,
		PID::MergePng,
		PID::MultilineExpBtn,
		PID::MultilineClpsBtn,
		PID::unused30,
		PID::BookmarkCurrentPng,
		PID::BookmarkCurrentWithCommentPng,
		PID::TimeJumpWarningPng,
		PID::RebuildMergeNeededPng,
		PID::eIMGUI_RESET_PNG,
		PID::eIMGUI_ZOOM_IN_PNG,
		PID::eIMGUI_ZOOM_OUT_PNG,
		PID::eIMGUI_ROTATE_LEFT_PNG,
		PID::eIMGUI_ROTATE_RIGHT_PNG,
		PID::LogFileError,
		PID::FileOpen,
		PID::AppAbout,
		PID::TimeOffset,
		PID::Find,
		PID::TOGGLE_BOOKMARK,
		PID::TOGGLE_BOOKMARK_COMMENT,
		PID::PREV_BOOKMARK,
		PID::NEXT_BOOKMARK,
		PID::CLEAR_BOOKMARKS,
		PID::FILTER_OFF,
		PID::FILTER_ON,
		PID::FILTER_CLEAR_ALL,
		PID::FILTER_QUICK_SET,
		PID::FILTER_QUICK_CLEAR,
		PID::MultilineExpBtn20x20,
		PID::MultilineClpsBtn20x20,
		PID::FindPrev,
		PID::FindNext,
		PID::FindSave,
		PID::FindRemove,
		PID::FindClose,
		PID::AddToHiliteList,
		PID::EditHiliteList,
		PID::eRm_Connecting,
		PID::eRm_Reading,
		PID::eErrorRmConnect,
		PID::eErrorRmReadFailed,
		PID::eErrorRmWriteLocalFailed,
		PID::StopFileRefresh,
		PID::StartFileRefresh,
		PID::eRmConnected,
		PID::FileIconServer,
		PID::FileIconApp,
		PID::FileIconConsole,
		PID::FileIconUser,
		PID::FileIconService,
		PID::FindAll,
		PID::FilterDeactivate,
		PID::FilterActivate,
