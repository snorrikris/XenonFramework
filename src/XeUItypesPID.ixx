	PREV_BOOKMARK = 47,
	NEXT_BOOKMARK = 48,
	CLEAR_BOOKMARKS = 49,
	FILTER_OFF = 50,
	FILTER_ON = 51,
	FILTER_CLEAR_ALL = 52,
	FILTER_QUICK_SET = 53,
	FILTER_QUICK_CLEAR = 54,
	MultilineExpBtn20x20 = 55,
	MultilineClpsBtn20x20 = 56,
	FindPrev = 57,
	FindNext = 58,
	FindSave = 59,
	FindRemove = 60,
	FindClose = 61,
	AddToHiliteList = 62,
	EditHiliteList = 63,
