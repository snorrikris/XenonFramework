	//	m_brushes.clear();
	//	m_pens.clear();
	//}
#pragma endregion XeUI_Functions

#pragma region LoadSaveThemeJson
public:
	virtual std::wstring LoadFromJson(const std::string& colorIDs_json,
		const std::string& theme_json, const std::vector<ThemeInfoJson>& all_theme_list) override
	{
		//DeletePensAndBrushes();
		std::wstring report;
		CID_Values cid_values;
		try
		{
			m_palette.Clear();
			auto j = json::parse(theme_json);
			std::string theme_name, based_on;
			j.at("01_Name").get_to(theme_name);
			m_theme_name = xet::fromUTF8toWStr(theme_name);
			j.at("02_IsAppDefined").get_to(m_isAppDefined);
			j.at("03_BasedOn").get_to(based_on);
			m_based_on = xet::fromUTF8toWStr(based_on);
			j.at("10_Palette").get_to(m_palette.GetPalette());
			j.at("20_CID_Value").get_to(cid_values.m_values);
		}
		catch (json::exception& e)
		{
			std::string err = e.what();
			XeASSERT(false);
			report += L"json parse failed. Error: " + xet::to_wstr(err) + L"\r\n";
		}

		XeTheme basedOnTheme;
		auto it = std::find_if(all_theme_list.cbegin(), all_theme_list.cend(),
			[&](const ThemeInfoJson& nfo)
			{ return nfo.m_theme_name == m_based_on; });
		if (it != all_theme_list.cend())
		{
			basedOnTheme.LoadFromJson(colorIDs_json,
				it->m_json_data, std::vector<ThemeInfoJson>());
			_FixUserThemeProblems(cid_values, basedOnTheme);
		}

		report += m_palette.Parse();

		report += _UpdateValuesUsingPalette(cid_values.m_values);

		report += m_colorIDs.LoadFromJson(colorIDs_json, cid_values);

		return report;
	}

	virtual std::wstring SaveThemeJson(const std::wstring& pathname, const std::wstring& theme_name) override
	{
		std::wstring based_on = m_isAppDefined ? m_theme_name : m_based_on;
		try
		{
			json j{ {"01_Name", xet::toUTF8(theme_name)}, {"02_IsAppDefined", false}, {"03_BasedOn", xet::toUTF8(based_on)},
				{"10_Palette", m_palette.GetPaletteConst()}, {"20_CID_Value", m_colorIDs.GetValues()} };
			std::string s = j.dump(4);
			WriteAllBytes(pathname.c_str(), s.c_str(), s.size());
			m_palette.ClearChanged();
			m_colorIDs.ClearChanged();
		}
		catch (json::exception& e)
		{
			XeASSERT(false);
			std::string err = e.what();
			return L"SaveThemeJson failed. Error: " + xet::to_wstr(err);
		}
		return L"";
	}

	static std::optional<ThemeInfoJson> ReadThemeInfo(const std::string& theme_json,
			const std::wstring& pathname)
	{
		try
		{
			ThemeInfoJson theme_info;
			auto j = json::parse(theme_json);
			std::string theme_name, based_on;
			j.at("01_Name").get_to(theme_name);
			j.at("02_IsAppDefined").get_to(theme_info.m_isAppDefined);
			j.at("03_BasedOn").get_to(based_on);
			theme_info.m_theme_name = xet::fromUTF8toWStr(theme_name);
			theme_info.m_based_on = xet::fromUTF8toWStr(based_on);
			theme_info.m_json_data = theme_json;
			theme_info.m_json_pathname = pathname;
			return theme_info;
		}
		catch (json::exception&) {}
		return std::nullopt;
	}

protected:
	void _FixUserThemeProblems(CID_Values& cid_values, XeTheme& basedOnTheme)
	{
		if (basedOnTheme.m_colorIDs.GetColorIDsConst().size() == 0)
		{
			return;
		}
		std::vector<PaletteColor>& this_palette = m_palette.GetPalette();
		for (const CID_Color& base_clr : basedOnTheme.m_colorIDs.GetColorIDsConst())
		{
			if (base_clr.m_CIDname == L"Invalid" || base_clr.m_CIDname == L"unused")
			{
				continue;
			}
			const CID_Value* pCIDvalue = cid_values.FindCID_Value(base_clr.m_CIDname);
			if (!pCIDvalue)	// CID name (from based on theme) does not exist in 'this' theme json data?
			{
				cid_values.m_values.push_back(CID_Value(base_clr.m_CIDname, base_clr.m_value, base_clr.m_rgb));
				m_colorIDs.SetChanged();
				if (!base_clr.m_value.starts_with(L"RGB("))
				{
					if (!m_palette.FindPaletteColorConst(base_clr.m_value))	// Palette label from based on theme exists?
					{
						const PaletteColor* pPalClr = basedOnTheme.m_palette.FindPaletteColorConst(base_clr.m_value);
						XeASSERT(pPalClr);
						if (pPalClr)
						{
							this_palette.push_back(*pPalClr);	// Add palette item from based on theme.
							m_palette.SetChanged();
						}
					}
				}
			}
		}
		for (auto it = cid_values.m_values.begin(); it != cid_values.m_values.end(); /*++it*/)
		{
			const CID_Color* pBaseClr = basedOnTheme.m_colorIDs.FindColorIDbyNameConst(it->m_CIDname);
			if (!pBaseClr)
			{
				it = cid_values.m_values.erase(it);
				m_colorIDs.SetChanged();
			}
			else
			{
				++it;
			}
		}
	}
#pragma endregion LoadSaveThemeJson

public:
	virtual bool IsInEditMode() const override { return m_isInEditMode; }
	virtual void SetEditMode(bool isEditmode) override { m_isInEditMode = isEditmode; }

	virtual bool IsChanged() const override
	{
		return IsPaletteChanged() || IsColorIDsChanged() || IsCID_list_Changed();
	}
	virtual bool IsPaletteChanged() const override { return m_palette.IsChanged(); }
	virtual bool IsColorIDsChanged() const override { return m_colorIDs.IsChanged(); }
	virtual bool IsCID_list_Changed() const override { return m_colorIDs.IsCID_list_Changed(); }

	virtual void ResetTheme(const std::vector<CID_Color>& colorIDs,
		const std::vector<PaletteColor>& palette) override
	{
		m_colorIDs.SetColorIDs(colorIDs);
		m_palette.SetPalette(palette);
	}

	virtual const std::vector<CID_Color>& GetColorIDsConst() const override
	{
		return m_colorIDs.GetColorIDsConst();
	}

	virtual const CID_Color* FindColorIDConst(CID id) const override
	{
		return m_colorIDs.FindColorIDConst(id);
	}

	virtual const CID_Color* FindColorIDbyNameConst(const std::wstring& name) const override
	{
		return m_colorIDs.FindColorIDbyNameConst(name);
	}

	virtual bool SetColor(CID ID, const std::wstring& def_name) override
	{
		const PaletteColor* pPaletteColor = m_palette.FindPaletteColorConst(def_name);
		if (pPaletteColor)
		{
			return m_colorIDs.SetColor(ID, def_name, pPaletteColor->m_rgb);
		}
		return false;
	}

	virtual bool SetColor(CID ID, COLORREF rgb) override
	{
		return m_colorIDs.SetColor(ID, rgb);
	}

	virtual const std::vector<PaletteColor>& GetPaletteConst() const override
	{
		return m_palette.GetPaletteConst();
	}

	virtual const PaletteColor* FindPaletteColorConst(const std::wstring& def_name) override
	{
		return m_palette.FindPaletteColorConst(def_name);
	}

#pragma region EditPalette
	virtual bool SetPaletteItemColor(const std::wstring& def_name, const std::wstring& def_value) override
	{
		if (m_palette.SetPaletteItemColor(def_name, def_value))
		{
			_OnPaletteItemChanged();
			return true;
		}
		return false;
	}

	virtual bool SetPaletteItemColor(const std::wstring& def_name, COLORREF rgb) override
	{
		if (m_palette.SetPaletteItemColor(def_name, rgb))
		{
			_OnPaletteItemChanged();
			return true;
		}
		return false;
	}

	virtual bool AddNewPaletteItem(const std::wstring& def_label) override
	{
		return m_palette.AddNewPaletteItem(def_label);
	}

	virtual bool RenamePaletteItem(const std::wstring& old_def_name, const std::wstring& new_def_name) override
	{
		bool isOk = m_palette.RenamePaletteItem(old_def_name, new_def_name);
		isOk |= m_colorIDs.RenamePaletteItem(old_def_name, new_def_name);
		return isOk;
	}

	virtual bool DeletePaletteItem(const std::wstring& def_label) override
	{
		const std::vector<CID_Color>& cids = m_colorIDs.GetColorIDsConst();
		int count = (int)std::count_if(cids.begin(), cids.end(),
			[&](const CID_Color& cid) { return cid.m_value == def_label; });
		XeASSERT(count == 0);
		if (count == 0)
		{
			return m_palette.DeletePaletteItem(def_label);
		}
		return false;
	}
#pragma endregion EditPalette

#pragma region Edit_CID_list
	virtual bool AddNewCIDname(const std::wstring& cid_name) override
	{
		return m_colorIDs.AddNewColorID(cid_name, L"");
	}

	virtual bool RenameCIDname(CID ID, const std::wstring& new_cid_name) override
	{
		return m_colorIDs.RenameCIDname(ID, new_cid_name);
	}

	virtual bool DeleteCID(CID ID) override
	{
		return m_colorIDs.DeleteCID(ID);
	}

	virtual bool SetCID_description(CID ID, const std::wstring& desc) override
	{
		return m_colorIDs.SetCID_description(ID, desc);
	}

	virtual std::wstring GetCID_changes_report() override
	{
		return m_colorIDs.GetCID_changes_report();
	}

	// Generate and save "ColorIDs.json" file.
	virtual std::wstring SaveColorIDsJson(const std::wstring& pathname) const override
	{
		return m_colorIDs.SaveToJson(pathname);
	}

	// Generate and Save "ColorIDs.h" file.
	virtual bool SaveColorIDsIncludeFile(const std::wstring& pathname) const override
	{
		std::string inclFileData = m_colorIDs.MakeColorIDsIncludeFileData();
		return WriteTextFile(pathname, inclFileData);
	}
#pragma endregion Edit_CID_list

protected:
	void _OnPaletteItemChanged()
	{
		std::vector<CID_Value> values = m_colorIDs.GetValues();
		_UpdateValuesUsingPalette(values);
		m_colorIDs.UpdateValues(values);
	}

	std::wstring _UpdateValuesUsingPalette(std::vector<CID_Value>& values)
	{
		std::wstring report;
		for (CID_Value& value : values)
		{
			if (!m_palette.ParsePaletteColor(value.m_def, value.m_rgb)
				&& !(value.m_CIDname == L"Invalid" || value.m_CIDname == L"unused"))
			{
				report += L"Not found RGB value for " + value.m_CIDname + L", Value: " + value.m_def + L"\r\n";
			}
		}
		return report;
	}
};

