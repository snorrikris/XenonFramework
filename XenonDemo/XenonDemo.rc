IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open file...\tCtrl-O",       ID__FILE_OPEN
        POPUP "&Recent files"
        BEGIN
            MENUITEM "MRU 1",                       ID_MRU_ITEM1
        END
        MENUITEM SEPARATOR
        MENUITEM "Open containing folder",      ID__OPENCONTAININGFOLDER
        MENUITEM "Filename to Clipboard",       ID__FILENAMETOCLIPBOARD
        MENUITEM "Full File Path to Clipboard", ID__FULLFILEPATHTOCLIPBOARD
        MENUITEM "&Close file",                 ID_CLOSE_CURRENT_FILE
        MENUITEM SEPARATOR
        MENUITEM "Close &all files",            ID_FILE_CLOSEALLWINDOWS
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID__APP_EXIT
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&1st Tab\tCtrl-Numpad 1",     ID_TAB_1STTAB
        MENUITEM "&2nd Tab\tCtrl-Numpad 2",     ID_TAB_2NDTAB
        MENUITEM "&3rd Tab\tCtrl-Numpad 3",     ID_TAB_3RDTAB
        MENUITEM "&4th Tab\tCtrl-Numpad 4",     ID_TAB_4THTAB
        MENUITEM "&5th Tab\tCtrl-Numpad 5",     ID_TAB_5THTAB
        MENUITEM "&6th Tab\tCtrl-Numpad 6",     ID_TAB_6THTAB
        MENUITEM "&7th Tab\tCtrl-Numpad 7",     ID_TAB_7THTAB
        MENUITEM "&8th Tab\tCtrl-Numpad 8",     ID_TAB_8THTAB
        MENUITEM "&9th Tab\tCtrl-Numpad 9",     ID_TAB_9THTAB
        MENUITEM SEPARATOR
        MENUITEM "&Previous Tab\tCtrl-Page up", ID_TAB_PREVTAB
        MENUITEM "&Next Tab\tCtrl-Page down",   ID_TAB_NEXTTAB
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "Set window &title...",        ID_FILE_SET_TITLE
        MENUITEM SEPARATOR
        MENUITEM "&Settings...",                ID_SHOW_SETTINGS
        MENUITEM SEPARATOR
        POPUP "Theme"
        BEGIN
            MENUITEM "{empty}",                     ID_THEME_LIST_ITEM1
        END
        MENUITEM "Theme editor...",             ID_TOOLS_THEMEEDITOR
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About 'this' application...", ID__APP_ABOUT
    END
END

IDR_TAB_CONTEXT_MENU MENU
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Open containing folder",      ID__OPENCONTAININGFOLDER
        MENUITEM SEPARATOR
        MENUITEM "Filename to Clipboard",       ID__FILENAMETOCLIPBOARD
        MENUITEM "Full File Path to Clipboard", ID__FULLFILEPATHTOCLIPBOARD
        MENUITEM SEPARATOR
